---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFAB from '../components/WhatsAppFAB.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string | URL;
  schema?: object;
}

const {
  title = 'VIVE-IA — Automatizá tu negocio con Inteligencia Artificial',
  description = 'Ordenamos, estructuramos y automatizamos tus procesos para que tu empresa crezca sin caos. Agencia IA en Argentina.',
  ogImage = '/images/og-image.jpg',
  canonicalURL = Astro.url,
  schema,
} = Astro.props;

const canonicalHref = typeof canonicalURL === 'string' ? canonicalURL : canonicalURL.href;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://vive-ia.com${ogImage}`;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'VIVE-IA',
  url: 'https://vive-ia.com',
  logo: 'https://vive-ia.com/images/logo-transparent.png',
  description: 'Agencia argentina especializada en automatización de procesos con inteligencia artificial.',
  address: { '@type': 'PostalAddress', addressCountry: 'AR' },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+54-9-266-525-8874',
    contactType: 'customer service',
    areaServed: 'AR',
    availableLanguage: 'Spanish',
  },
  sameAs: [
    'https://www.instagram.com/vive_ia',
    'https://www.youtube.com/@ViveIA-AgenciadeAutomatizaci%C3%B3n',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VIVE-IA',
  url: 'https://vive-ia.com',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VIVE-IA" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:site" content="@vive_ia" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- AOS -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css"
    />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class="bg-brand-bg text-text-primary font-sans antialiased">

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppFAB />

    <!-- AOS init -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"
      is:inline
    ></script>
    <script is:inline>
      AOS.init({
        duration: 700,
        easing: 'ease-out-cubic',
        once: true,
        offset: 60,
      });
    </script>
  </body>
</html>
