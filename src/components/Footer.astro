---
const year = new Date().getFullYear();

const pages = [
  { label: 'Inicio', href: '/' },
  { label: 'Quiénes Somos', href: '/quienes-somos' },
  { label: 'Contacto', href: '/contacto' },
];

const solutions = [
  { label: 'Agentes para E-commerce', href: '/soluciones/ecommerce' },
  { label: 'Agentes para Mentores', href: '/soluciones/mentores-marcas-personales' },
];
---

<footer class="bg-[#0A0A0F] border-t border-white/[0.06] mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Marca -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-4">
          <img
            src="/images/logo-transparent.png"
            alt="VIVE-IA"
            width="120"
            height="36"
            class="h-16 w-auto"
          />
        </a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
          Ordenamos, estructuramos y automatizamos tus procesos con inteligencia artificial.
          Tecnología con propósito para que tu negocio crezca sin caos.
        </p>
        <div class="flex items-center gap-4 mt-6">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/vive_ia"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de VIVE-IA"
            class="w-9 h-9 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08]
                   text-slate-400 hover:text-white hover:border-violet-600/40 hover:bg-violet-600/10
                   transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/5492665258874"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp de VIVE-IA"
            class="w-9 h-9 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08]
                   text-slate-400 hover:text-white hover:border-green-600/40 hover:bg-green-600/10
                   transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@ViveIA-AgenciadeAutomatizaci%C3%B3n"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube VIVE-IA"
            class="w-9 h-9 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08]
                   text-slate-400 hover:text-white hover:border-red-600/40 hover:bg-red-600/10
                   transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Páginas -->
      <div>
        <h3 class="text-slate-200 text-sm font-semibold uppercase tracking-wider mb-4">Páginas</h3>
        <ul class="space-y-2.5">
          {pages.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Soluciones + Contacto -->
      <div>
        <h3 class="text-slate-200 text-sm font-semibold uppercase tracking-wider mb-4">Soluciones</h3>
        <ul class="space-y-2.5 mb-8">
          {solutions.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-slate-200 text-sm font-semibold uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-2.5">
          <li>
            <a
              href="mailto:contacto@vive-ia.com"
              class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
            >
              contacto@vive-ia.com
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/5492665258874"
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
            >
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/[0.06] mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-sm">
        © {year} VIVE-IA. Todos los derechos reservados.
      </p>
      <p class="text-slate-600 text-xs">
        Hecho con propósito en Argentina 🇦🇷
      </p>
    </div>
  </div>
</footer>
