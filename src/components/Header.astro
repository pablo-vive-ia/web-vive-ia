---
const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Quiénes Somos', href: '/quienes-somos' },
];

const solucionesLinks = [
  { label: 'Agentes para E-commerce', href: '/soluciones/ecommerce', desc: 'Automatizá ventas y soporte' },
  { label: 'Agentes para Mentores', href: '/soluciones/mentores-marcas-personales', desc: 'Escalá tu marca personal' },
  { label: 'Desarrollos personalizados', href: '/desarrollos', desc: 'Páginas web, apps y más' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/[0.06]"
  style="background: rgba(10,10,15,0.85);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">

      <!-- Logo -->
      <a href="/">
        <img src="/images/logo-transparent.png" alt="VIVE-IA" class="h-18 w-auto object-contain" />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200
              ${currentPath === link.href
                ? 'text-white bg-white/[0.08]'
                : 'text-slate-400 hover:text-white hover:bg-white/[0.05]'
              }`}
          >
            {link.label}
          </a>
        ))}

        <!-- Dropdown Soluciones -->
        <div class="relative group">
          <button
            class={`flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200
              ${currentPath.startsWith('/soluciones')
                ? 'text-white bg-white/[0.08]'
                : 'text-slate-400 hover:text-white hover:bg-white/[0.05]'
              }`}
            aria-haspopup="true"
          >
            Soluciones
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div
            class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-64
                   opacity-0 invisible group-hover:opacity-100 group-hover:visible
                   transition-all duration-200 translate-y-1 group-hover:translate-y-0"
          >
            <div class="bg-[#111118] border border-white/[0.08] rounded-xl shadow-xl p-2">
              {solucionesLinks.map((item) => (
                <a
                  href={item.href}
                  class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-white/[0.06] transition-colors duration-200 group/item"
                >
                  <span class="text-sm font-medium text-slate-200 group-hover/item:text-white transition-colors">
                    {item.label}
                  </span>
                  <span class="text-xs text-slate-500">{item.desc}</span>
                </a>
              ))}
              <div class="border-t border-white/[0.08] mt-1 pt-1">
                <a
                  href="/contacto"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex flex-col gap-0.5 px-4 py-3 rounded-lg hover:bg-violet-600/10 transition-colors duration-200 group/item"
                >
                  <span class="text-sm font-medium text-violet-400 group-hover/item:text-violet-300 transition-colors">
                    Más agentes ✦
                  </span>
                  <span class="text-xs text-slate-500">Contanos tu caso y lo analizamos</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <a
          href="/contacto"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200
            ${currentPath === '/contacto'
              ? 'text-white bg-white/[0.08]'
              : 'text-slate-400 hover:text-white hover:bg-white/[0.05]'
            }`}
        >
          Contacto
        </a>
      </nav>

      <!-- CTA desktop -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="/contacto"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold
                 bg-violet-600 hover:bg-violet-500 text-white
                 shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:shadow-[0_0_28px_rgba(124,58,237,0.5)]
                 transition-all duration-300"
        >
          Agendar diagnóstico
        </a>
      </div>

      <!-- Hamburguesa mobile -->
      <button
        id="menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 rounded-lg
               hover:bg-white/[0.06] transition-colors duration-200 gap-1.5"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-white/[0.06] bg-[#0A0A0F]"
  >
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200
            ${currentPath === link.href
              ? 'text-white bg-white/[0.08]'
              : 'text-slate-400 hover:text-white hover:bg-white/[0.05]'
            }`}
        >
          {link.label}
        </a>
      ))}

      <!-- Soluciones expandible en mobile -->
      <div>
        <button
          id="solutions-toggle"
          class="w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/[0.05] transition-colors duration-200"
        >
          Soluciones
          <svg id="solutions-icon" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="solutions-submenu" class="hidden pl-4 flex flex-col gap-1 mt-1">
          {solucionesLinks.map((item) => (
            <a
              href={item.href}
              class="px-4 py-2.5 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/[0.05] transition-colors duration-200"
            >
              {item.label}
            </a>
          ))}
          <a
            href="https://n8n.vive-ia.com/form/e563e490-0ed3-4500-be54-80343c3c4687"
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2.5 rounded-lg text-sm text-violet-400 hover:text-violet-300 hover:bg-violet-600/10 transition-colors duration-200 border-t border-white/[0.06] mt-1 pt-3"
          >
            Más agentes ✦
          </a>
        </div>
      </div>

      <a
        href="/contacto"
        class={`px-4 py-3 rounded-lg text-sm font-medium transition-colors duration-200
          ${currentPath === '/contacto'
            ? 'text-white bg-white/[0.08]'
            : 'text-slate-400 hover:text-white hover:bg-white/[0.05]'
          }`}
      >
        Contacto
      </a>

      <div class="pt-2 border-t border-white/[0.06] mt-2">
        <a
          href="/contacto"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 px-4 py-3 rounded-lg text-sm font-semibold
                 bg-violet-600 hover:bg-violet-500 text-white transition-all duration-300"
        >
          Agendar diagnóstico gratuito
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer para compensar el header fixed -->
<div class="h-16 lg:h-18"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll('.hamburger-line');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    // Animar hamburguesa → X
    if (isOpen) {
      lines[0]?.classList.add('rotate-45', 'translate-y-2');
      lines[1]?.classList.add('opacity-0');
      lines[2]?.classList.add('-rotate-45', '-translate-y-2');
    } else {
      lines[0]?.classList.remove('rotate-45', 'translate-y-2');
      lines[1]?.classList.remove('opacity-0');
      lines[2]?.classList.remove('-rotate-45', '-translate-y-2');
    }
  });

  // Submenu soluciones mobile
  const solutionsToggle = document.getElementById('solutions-toggle');
  const solutionsSubmenu = document.getElementById('solutions-submenu');
  const solutionsIcon = document.getElementById('solutions-icon');

  solutionsToggle?.addEventListener('click', () => {
    solutionsSubmenu?.classList.toggle('hidden');
    solutionsIcon?.classList.toggle('rotate-180');
  });
</script>
