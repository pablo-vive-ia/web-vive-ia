---
// HeroPhrase.astro — subtítulo dinámico generado por Gemini con efecto typewriter
// No recibe props
---

<div class="min-h-[2rem] flex items-center justify-center md:justify-start">
  <p id="hero-phrase" class="text-slate-300 text-xl leading-relaxed max-w-xl">
    <span id="phrase-text"></span><span id="cursor" class="text-violet-500 cursor-blink">|</span>
  </p>
</div>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .cursor-blink {
    animation: blink 0.7s step-end infinite;
  }
</style>

<script>
  const PHRASE = 'Ordenamos, estructuramos y automatizamos tus procesos para que puedas crecer sin caos.';
  const DELAY_MS = 38;

  const phraseSpan = document.getElementById('phrase-text') as HTMLElement;
  const cursorSpan = document.getElementById('cursor') as HTMLElement;

  if (phraseSpan && cursorSpan) {
    let i = 0;
    const timer = setInterval(() => {
      phraseSpan.textContent += PHRASE[i];
      i++;
      if (i >= PHRASE.length) {
        clearInterval(timer);
        cursorSpan.style.display = 'none';
      }
    }, DELAY_MS);
  }
</script>
