---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBadge from '../components/SectionBadge.astro';
---

<BaseLayout
  title="Contacto — VIVE-IA"
  description="Agendá tu diagnóstico gratuito y descubrí cómo automatizar tu negocio con inteligencia artificial."
>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 1. HERO                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="relative px-4 sm:px-6 py-24 bg-[#0A0A0F] overflow-hidden">

    <!-- Canvas 3D -->
    <canvas id="canvas-contacto" class="absolute inset-0 w-full h-full" style="z-index:0;"></canvas>

    <!-- Overlay suave -->
    <div class="absolute inset-0 pointer-events-none" style="z-index:1; background: radial-gradient(ellipse at center, rgba(10,10,15,0.1) 0%, rgba(10,10,15,0.55) 100%);"></div>

    <div class="max-w-3xl mx-auto text-center relative space-y-6" style="z-index:2;" data-aos="fade-up">
      <SectionBadge text="Hablemos del futuro" />
      <h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-tight text-white">
        ¿Listo para ordenar y{' '}
        <span style="background: linear-gradient(135deg, #A855F7 0%, #06B6D4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          automatizar
        </span><br />
        tu negocio?
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto leading-relaxed">
        Transformamos procesos manuales en flujos inteligentes. El primer paso hacia
        la escala comienza con una conversación.
      </p>
    </div>
  </section>

  <script>
    import * as THREE from 'three';

    const canvasContacto = document.getElementById('canvas-contacto') as HTMLCanvasElement;
    if (canvasContacto) {
      const section = canvasContacto.parentElement!;
      const rendererC = new THREE.WebGLRenderer({ canvas: canvasContacto, antialias: true, alpha: true });
      rendererC.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      rendererC.setClearColor(0x000000, 0);
      rendererC.setSize(section.offsetWidth, section.offsetHeight);

      const sceneC = new THREE.Scene();
      const cameraC = new THREE.PerspectiveCamera(55, section.offsetWidth / section.offsetHeight, 0.1, 100);
      cameraC.position.z = 5.5;

      // — Esfera neuronal: nodos distribuidos sobre superficie de esfera —
      const NODE_COUNT = 90;
      const SPHERE_R = 2.2;
      const CONNECT_DIST = 1.4;

      // Distribución Fibonacci para nodos uniformes en esfera
      const nodePositions: THREE.Vector3[] = [];
      const flashPhases = new Float32Array(NODE_COUNT);
      const flashSpeeds = new Float32Array(NODE_COUNT);

      const golden = Math.PI * (3 - Math.sqrt(5));
      for (let i = 0; i < NODE_COUNT; i++) {
        const y = 1 - (i / (NODE_COUNT - 1)) * 2;
        const r = Math.sqrt(1 - y * y);
        const theta = golden * i;
        nodePositions.push(new THREE.Vector3(
          Math.cos(theta) * r * SPHERE_R,
          y * SPHERE_R,
          Math.sin(theta) * r * SPHERE_R,
        ));
        flashPhases[i] = Math.random() * Math.PI * 2;
        flashSpeeds[i] = 0.4 + Math.random() * 0.9;
      }

      // Geometría de puntos con atributo flash
      const flashAttrC = new THREE.BufferAttribute(new Float32Array(NODE_COUNT), 1);
      const pointsGeoC = new THREE.BufferGeometry();
      const posArrC = new Float32Array(NODE_COUNT * 3);
      nodePositions.forEach((p, i) => {
        posArrC[i * 3] = p.x; posArrC[i * 3 + 1] = p.y; posArrC[i * 3 + 2] = p.z;
      });
      pointsGeoC.setAttribute('position', new THREE.BufferAttribute(posArrC, 3));
      pointsGeoC.setAttribute('flash', flashAttrC);

      const pointsMatC = new THREE.ShaderMaterial({
        transparent: true,
        uniforms: { pointSize: { value: 5.0 * Math.min(window.devicePixelRatio, 2) } },
        vertexShader: `
          attribute float flash;
          varying float vFlash;
          varying vec3 vPos;
          uniform float pointSize;
          void main() {
            vFlash = flash;
            vPos = position;
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = pointSize * (1.0 + 0.5 * flash);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          varying float vFlash;
          varying vec3 vPos;
          void main() {
            float d = length(gl_PointCoord - vec2(0.5));
            if (d > 0.5) discard;
            float yN = (vPos.y + 2.2) / 4.4;
            vec3 cA = vec3(0.486, 0.227, 0.929); // violet
            vec3 cB = vec3(0.024, 0.714, 0.831); // cyan
            vec3 col = mix(cA, cB, clamp(yN, 0.0, 1.0));
            float alpha = (0.4 + 0.45 * vFlash) * (1.0 - smoothstep(0.3, 0.5, d));
            gl_FragColor = vec4(col, alpha);
          }
        `,
      });
      const pointsMeshC = new THREE.Points(pointsGeoC, pointsMatC);
      sceneC.add(pointsMeshC);

      // — Líneas de conexión —
      const linesMatC = new THREE.LineBasicMaterial({ color: 0x7C3AED, transparent: true, opacity: 0.1 });
      const linesGeoC = new THREE.BufferGeometry();
      const linesArrC = new Float32Array(NODE_COUNT * NODE_COUNT * 6);
      linesGeoC.setAttribute('position', new THREE.BufferAttribute(linesArrC, 3));
      const linesMeshC = new THREE.LineSegments(linesGeoC, linesMatC);
      sceneC.add(linesMeshC);

      // — Glow central (esfera interior transparente) —
      const glowGeo = new THREE.SphereGeometry(1.0, 32, 32);
      const glowMat = new THREE.MeshBasicMaterial({
        color: 0x7C3AED,
        transparent: true,
        opacity: 0.03,
        side: THREE.BackSide,
      });
      sceneC.add(new THREE.Mesh(glowGeo, glowMat));

      // Grupo que rota
      const groupC = new THREE.Group();
      groupC.add(pointsMeshC);
      groupC.add(linesMeshC);
      sceneC.add(groupC);
      sceneC.remove(pointsMeshC);
      sceneC.remove(linesMeshC);

      function updateLinesC() {
        const arr = linesGeoC.attributes.position.array as Float32Array;
        let idx = 0;
        for (let i = 0; i < NODE_COUNT; i++) {
          for (let j = i + 1; j < NODE_COUNT; j++) {
            const dist = nodePositions[i].distanceTo(nodePositions[j]);
            if (dist < CONNECT_DIST) {
              arr[idx++] = nodePositions[i].x; arr[idx++] = nodePositions[i].y; arr[idx++] = nodePositions[i].z;
              arr[idx++] = nodePositions[j].x; arr[idx++] = nodePositions[j].y; arr[idx++] = nodePositions[j].z;
            }
          }
        }
        while (idx < arr.length) arr[idx++] = 0;
        linesGeoC.attributes.position.needsUpdate = true;
        linesGeoC.setDrawRange(0, idx / 3);
      }

      // Calcular líneas una sola vez (nodos fijos en la esfera)
      updateLinesC();

      const startC = performance.now();

      function animateC() {
        requestAnimationFrame(animateC);
        const t = (performance.now() - startC) / 1000;

        // Flash por nodo
        const fArr = flashAttrC.array as Float32Array;
        for (let i = 0; i < NODE_COUNT; i++) {
          fArr[i] = Math.max(0, Math.sin(t * flashSpeeds[i] + flashPhases[i]));
        }
        flashAttrC.needsUpdate = true;

        // Rotación lenta y elegante
        groupC.rotation.y = t * 0.12;
        groupC.rotation.x = Math.sin(t * 0.07) * 0.18;

        rendererC.render(sceneC, cameraC);
      }

      animateC();

      window.addEventListener('resize', () => {
        const w = section.offsetWidth;
        const h = section.offsetHeight;
        rendererC.setSize(w, h);
        cameraC.aspect = w / h;
        cameraC.updateProjectionMatrix();
      });
    }
  </script>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 2. WHATSAPP                                   -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-10 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-4xl mx-auto">
      <div
        data-aos="fade-up"
        class="group p-8 rounded-2xl bg-[#111118] border border-white/[0.06]
               hover:border-[#25D366]/30 transition-all duration-300 flex flex-col sm:flex-row items-center justify-between gap-6"
      >
        <div>
          <h3 class="text-white font-semibold text-xl mb-1">¿Preferís algo más directo?</h3>
          <p class="text-slate-400 text-sm">Escribinos por WhatsApp y analizamos tu caso en el día, sin formularios.</p>
        </div>
        <a
          href="https://wa.me/5492665258874"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 px-6 py-3 rounded-xl bg-[#25D366] hover:bg-[#1ebe5a] text-white font-bold
                 flex items-center justify-center gap-2 transition-all duration-300"
        >
          👉 Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 3. FORMULARIO + VALOR                        -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

        <!-- FORMULARIO (izquierda) -->
        <div class="lg:col-span-7 space-y-8" data-aos="fade-right">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2">Envianos un mensaje</h2>
            <p class="text-slate-400">Contanos sobre tu negocio y te ayudamos a automatizarlo con IA.</p>
          </div>

          <form id="contact-form" class="space-y-6" novalidate>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Apellido y nombre <span class="text-red-400">*</span>
                </label>
                <input
                  type="text"
                  name="nombre"
                  required
                  placeholder="Ej. Juan Pérez"
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-200 placeholder-slate-600
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Empresa / Proyecto <span class="text-red-400">*</span>
                </label>
                <input
                  type="text"
                  name="empresa"
                  required
                  placeholder="Nombre de tu negocio"
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-200 placeholder-slate-600
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Correo electrónico <span class="text-red-400">*</span>
                </label>
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="juan@empresa.com"
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-200 placeholder-slate-600
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Teléfono de contacto <span class="text-red-400">*</span>
                </label>
                <input
                  type="tel"
                  name="telefono"
                  required
                  placeholder="+54 9 ..."
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-200 placeholder-slate-600
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Tu presupuesto <span class="text-red-400">*</span>
                </label>
                <select
                  name="presupuesto"
                  required
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-300
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200 appearance-none"
                >
                  <option value="">Seleccioná tu presupuesto...</option>
                  <option>Hasta USD 500</option>
                  <option>USD 500 - 1.000</option>
                  <option>USD 1.000 - 3.000</option>
                  <option>Más de USD 3.000</option>
                </select>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                  Tu red social
                </label>
                <input
                  type="text"
                  name="red_social"
                  placeholder="Ej. @vive_ia"
                  class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                         text-slate-200 placeholder-slate-600
                         focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                         outline-none transition-all duration-200"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-xs font-semibold uppercase tracking-wider text-slate-300">
                ¿Qué te gustaría automatizar? <span class="text-red-400">*</span>
              </label>
              <textarea
                name="mensaje"
                required
                rows="4"
                placeholder="Describí brevemente el proceso que querés optimizar..."
                class="w-full bg-[#0A0A0F] border border-white/[0.08] rounded-xl px-4 py-3
                       text-slate-200 placeholder-slate-600
                       focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50
                       outline-none transition-all duration-200 resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-bold text-lg
                     shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:shadow-[0_0_30px_rgba(124,58,237,0.5)]
                     transition-all duration-300 active:scale-[0.98]"
            >
              Quiero automatizar mi negocio
            </button>

            <!-- Mensajes de estado -->
            <div id="form-success" class="hidden p-4 rounded-xl bg-green-900/20 border border-green-500/30 text-green-400 text-sm text-center">
              ✓ Mensaje enviado. Te contactaremos en menos de 24 horas.
            </div>
            <div id="form-error" class="hidden p-4 rounded-xl bg-red-900/20 border border-red-500/30 text-red-400 text-sm text-center">
              Ocurrió un error. Escribinos por WhatsApp y lo resolvemos.
            </div>
          </form>
        </div>

        <!-- VALOR (derecha) -->
        <div class="lg:col-span-5 space-y-12" data-aos="fade-left" data-aos-delay="100">

          <!-- Qué pasa después -->
          <div class="space-y-6">
            <h3 class="text-white font-bold text-2xl">¿Qué pasa después?</h3>
            <ul class="space-y-5">
              {[
                {
                  label: 'Análisis Inicial',
                  detail: 'Revisamos tu solicitud y agendamos una llamada técnica.',
                  active: true,
                },
                {
                  label: 'Propuesta de Valor',
                  detail: 'Diseñamos una arquitectura de IA a medida para tus procesos.',
                  active: false,
                },
                {
                  label: 'Implementación',
                  detail: 'Desplegamos y testeamos hasta que todo funcione en piloto automático.',
                  active: false,
                },
              ].map((step, i) => (
                <li class="flex items-start gap-4">
                  <div class={`mt-1 w-5 h-5 rounded-full border-2 flex-shrink-0 flex items-center justify-center
                               ${i === 0 ? 'border-violet-500' : i === 1 ? 'border-violet-500/30' : 'border-violet-500/10'}`}>
                    <div class={`w-2 h-2 rounded-full
                                 ${i === 0 ? 'bg-violet-500' : i === 1 ? 'bg-violet-500/30' : 'bg-violet-500/10'}`}></div>
                  </div>
                  <div>
                    <p class="text-white font-medium">{step.label}</p>
                    <p class="text-slate-500 text-sm mt-0.5">{step.detail}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Por qué VIVE-IA -->
          <div class="space-y-4">
            <h3 class="text-white font-bold text-2xl">¿Por qué trabajar con VIVE-IA?</h3>
            <div class="space-y-3">
              {[
                'Primero ordenamos tu negocio',
                'Después estructuramos tus procesos',
                'Y recién ahí automatizamos',
              ].map((item) => (
                <div class="flex items-center gap-3 p-4 bg-[#111118] rounded-xl border border-white/[0.06]">
                  <svg class="w-5 h-5 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1.177 14.828l-3.535-3.535 1.414-1.414 2.121 2.121 4.95-4.95 1.414 1.414-5.364 5.364z"/>
                  </svg>
                  <span class="text-slate-300 text-sm font-medium">{item}</span>
                </div>
              ))}
            </div>
            <p class="text-slate-400 text-sm">Así logramos resultados reales y sostenibles.</p>
          </div>

          <!-- Cita -->
          <div class="pt-6 border-t border-white/[0.06]">
            <p class="text-lg italic font-light text-slate-400 leading-relaxed">
              "La inteligencia artificial no reemplazará a los humanos, pero los humanos que
              usan IA reemplazarán a los que no la usan."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 4. CONFIANZA                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-4xl mx-auto" data-aos="fade-up">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div class="p-6 rounded-xl bg-[#111118] border border-white/[0.06]">
          <img src="/images/respuesta-24.png" alt="Respuesta en menos de 24hs" class="w-12 h-12 object-contain mx-auto mb-3" loading="lazy" />
          <p class="text-slate-400 text-sm font-medium">Respuesta en menos de 24hs</p>
        </div>
        <div class="p-6 rounded-xl bg-[#111118] border border-white/[0.06]">
          <img src="/images/sin-compromiso.png" alt="Sin compromiso inicial" class="w-12 h-12 object-contain mx-auto mb-3" loading="lazy" />
          <p class="text-slate-400 text-sm font-medium">Sin compromiso inicial</p>
        </div>
        <div class="p-6 rounded-xl bg-[#111118] border border-white/[0.06]">
          <img src="/images/diagnostico.png" alt="Diagnóstico 100% confidencial" class="w-12 h-12 object-contain mx-auto mb-3" loading="lazy" />
          <p class="text-slate-400 text-sm font-medium">Diagnóstico 100% confidencial</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 5. CIERRE EMOCIONAL                           -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F] text-center">
    <p class="text-xl md:text-2xl text-slate-300 italic max-w-2xl mx-auto leading-relaxed">
      "Este puede ser el paso que cambie la forma en que funciona tu negocio."
    </p>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');

    try {
      const { nombre, empresa, email, telefono, presupuesto, red_social, mensaje } = data as Record<string, string>;
      await fetch('https://n8n.vive-ia.com/webhook/contacto-vive-ia', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, empresa, email, telefono, presupuesto, red_social, mensaje }),
      });
      successEl?.classList.remove('hidden');
      errorEl?.classList.add('hidden');
      form.reset();
    } catch {
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
    }
  });
</script>
