---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBadge from '../../components/SectionBadge.astro';
import MetricCounter from '../../components/MetricCounter.astro';

const problemas = [
  {
    image: '/images/carrito-abandonado.png',
    title: 'Carritos abandonados',
    description: 'El 70% de tus clientes potenciales se van sin comprar por falta de asistencia inmediata.',
  },
  {
    image: '/images/tareas-manuales.png',
    title: 'Tareas manuales',
    description: 'Tu equipo pierde horas respondiendo "¿dónde está mi pedido?" o "¿tienen stock?".',
  },
  {
    image: '/images/baja-retencion.png',
    title: 'Baja retención',
    description: 'Sin un seguimiento post-venta personalizado, los clientes rara vez vuelven a comprar.',
  },
  {
    image: '/images/falta-integracion.png',
    title: 'Falta de integración',
    description: 'Tus sistemas no hablan entre sí, causando fricción en el proceso de compra.',
  },
  {
    image: '/images/soporte-lento.png',
    title: 'Soporte lento',
    description: 'Tiempos de respuesta superiores a 2 horas matan la intención de compra del usuario.',
  },
  {
    image: '/images/escalabilidad.png',
    title: 'Escalabilidad nula',
    description: 'En épocas de alta demanda (Hot Sale, Navidad), tu equipo colapsa y perdés ventas.',
  },
];

const capacidades = [
  {
    title: 'Atención Instantánea 24/7',
    description: 'Respuestas en menos de 3 segundos, siempre disponible.',
  },
  {
    title: 'Venta Sugestiva Inteligente',
    description: 'Recomienda productos basados en el comportamiento del usuario.',
  },
  {
    title: 'Gestión de Logística Automática',
    description: 'Rastreo de pedidos e incidencias sin intervención humana.',
  },
];

const beneficios = [
  {
    image: '/images/escala.png',
    title: 'Escala masiva',
    description: 'Atendé a 1 o 10.000 personas al mismo tiempo sin degradar la calidad.',
  },
  {
    image: '/images/data-analisis.png',
    title: 'Data Analytics',
    description: 'Descubrí por qué tus clientes no compran y optimizá tu catálogo con insights reales.',
  },
  {
    image: '/images/multilenguaje.png',
    title: 'Multilenguaje',
    description: 'Vendé en cualquier mercado. Tu agente habla más de 50 idiomas con fluidez.',
  },
  {
    image: '/images/omnicanalidad.png',
    title: 'Omnicanalidad',
    description: 'Mismo cerebro en WhatsApp, Instagram, Web y Facebook Messenger.',
  },
  {
    image: '/images/seguridad.png',
    title: 'Seguridad garantizada',
    description: 'Tratamiento de datos personales bajo los más altos estándares internacionales.',
  },
  {
    image: '/images/setup.png',
    title: 'Setup Rápido',
    description: 'Implementación en menos de 15 días con entrenamiento personalizado.',
  },
];

const planes = [
  {
    nombre: 'Bronce',
    logo: '/images/logo-bronce.png',
    features: [
      'Información sobre productos, envíos y medios de pago',
      'Derivación inteligente a humano según necesidad',
      'Configuración básica y soporte',
    ],
    destacado: false,
    cta: 'Quiero el Plan Bronce',
  },
  {
    nombre: 'Plata',
    logo: '/images/logo-plata.png',
    features: [
      'Agente que asesora y recomienda productos personalizados',
      'Calificación y segmentación inteligente de clientes',
      'Reportes detallados de interacción y conversión',
      'Integración avanzada con e-commerce y CRM',
    ],
    destacado: true,
    cta: 'Quiero el Plan Plata',
  },
  {
    nombre: 'Oro',
    logo: '/images/logo-oro.png',
    features: [
      'IA conversacional de última generación',
      'Seguimiento automático a carritos abandonados',
      'Automatización de embudos post-compra y remarketing',
    ],
    destacado: false,
    cta: 'Quiero el Plan Oro',
  },
];
---

<BaseLayout
  title="Agentes IA para E-commerce — VIVE-IA"
  description="Automatizá tu tienda online con agentes conversacionales. Recuperá carritos, mejorá la atención y vendé más las 24hs."
>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 1. HERO                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden">
    <!-- Video de fondo: rectángulo vertical centrado (tamaño celular) -->
    <div class="absolute inset-0 flex items-center justify-center z-0 pointer-events-none">
      <div class="relative w-[280px] h-[498px] rounded-3xl overflow-hidden opacity-70">
        <iframe
          src="https://www.youtube.com/embed/CGhpnVBpw_8?autoplay=1&mute=1&loop=1&playlist=CGhpnVBpw_8&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          allow="autoplay; encrypted-media"
          allowfullscreen
          title="VIVE-IA E-commerce"
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 border-none"
          style="width:280px; height:498px;"
        ></iframe>
      </div>
    </div>

    <!-- Overlay oscuro degradado -->
    <div
      class="absolute inset-0 z-10"
      style="background: linear-gradient(135deg, rgba(10,10,15,0.88) 0%, rgba(10,10,15,0.72) 50%, rgba(10,10,15,0.88) 100%);"
    ></div>

    <!-- Partículas decorativas -->
    <div class="absolute top-20 right-20 w-72 h-72 rounded-full opacity-10 blur-3xl z-10"
         style="background: radial-gradient(circle, #7C3AED, transparent);"></div>
    <div class="absolute bottom-20 left-10 w-56 h-56 rounded-full opacity-8 blur-3xl z-10"
         style="background: radial-gradient(circle, #06B6D4, transparent);"></div>

    <!-- Contenido -->
    <div class="relative z-20 max-w-4xl mx-auto text-left px-4 sm:px-6 py-24" data-aos="fade-up">
      <!-- Pill badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                  bg-white/[0.06] border border-violet-600/30 mb-8">
        <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
        <span class="text-violet-400 text-xs font-bold uppercase tracking-widest">Inteligencia Conversacional</span>
      </div>

      <h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-tight text-white mb-6 leading-[1.1]">
        Agentes conversacionales para{' '}
        <span style="background: linear-gradient(135deg, #A855F7 0%, #06B6D4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          E-commerce
        </span>
      </h1>

      <p class="text-xl text-slate-400 max-w-2xl mb-10 leading-relaxed">
        Transformá tu tienda online con IA que vende, atiende y fideliza 24/7.
        Reducí el abandono de carritos y escalá tus ventas sin aumentar el equipo.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-lg font-bold text-lg text-white
                 bg-violet-600 hover:bg-violet-500
                 shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:shadow-[0_0_30px_rgba(124,58,237,0.5)]
                 transition-all duration-300"
        >
          ¡Lo necesito!
        </a>
        <a
          href="https://wa.me/5492665258874"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-lg font-bold text-lg
                 bg-[#25D366] hover:bg-[#1ebe5a] text-white
                 transition-all duration-300"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 2. MÉTRICAS                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-14 px-4 sm:px-6 bg-[#0D0D14] border-t border-b border-white/[0.06]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-10 text-center">
      <div data-aos="fade-up" data-aos-delay="0">
        <div class="text-4xl font-extrabold text-white mb-2">50+</div>
        <p class="text-slate-500 uppercase tracking-widest text-xs font-semibold">Carritos recuperados/mes</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="100">
        <MetricCounter value={1150} prefix="+" suffix="%" label="ROI en implementación" />
      </div>
      <div data-aos="fade-up" data-aos-delay="200">
        <div class="text-4xl font-extrabold text-white mb-2">24/7</div>
        <p class="text-slate-500 uppercase tracking-widest text-xs font-semibold">Disponibilidad garantizada</p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 3. PROBLEMAS                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="El problema" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          ¿Tu E-commerce sufre de estos problemas?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {problemas.map((p, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={String((i % 3) * 100)}
            class="rounded-2xl bg-[#111118] border border-red-900/20
                   hover:border-red-900/40 transition-all duration-300 overflow-hidden"
          >
            <img
              src={p.image}
              alt={p.title}
              class="w-full h-28 object-cover object-center rounded-t-xl"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="text-white font-semibold text-lg mb-3">{p.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{p.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 4. QUÉ ES UN AGENTE CONVERSACIONAL           -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div data-aos="fade-right">
          <SectionBadge text="La solución" />
          <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-6">
            ¿Qué es un agente conversacional?
          </h2>
          <p class="text-slate-400 text-lg leading-relaxed mb-8">
            No es un simple chatbot. Es un experto en ventas digital que entiende el contexto,
            conoce tu catálogo y actúa proactivamente para cerrar ventas, tal como lo haría
            tu mejor vendedor.
          </p>

          <ul class="space-y-5">
            {capacidades.map((c, i) => (
              <li class="flex items-start gap-4" data-aos="fade-right" data-aos-delay={String(i * 80)}>
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-violet-600/20 border border-violet-600/40
                             flex items-center justify-center mt-0.5">
                  <svg class="w-3.5 h-3.5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <div>
                  <h4 class="text-white font-semibold mb-1">{c.title}</h4>
                  <p class="text-slate-400 text-sm">{c.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Panel decorativo derecha -->
        <div data-aos="fade-left" data-aos-delay="100">
          <div class="relative p-8 rounded-2xl bg-[#111118] border border-white/[0.06]
                      shadow-[0_0_60px_rgba(124,58,237,0.08)]">
            <!-- Chat simulado -->
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex-shrink-0 flex items-center justify-center text-xs text-slate-300">👤</div>
                <div class="bg-[#1A1A28] rounded-2xl rounded-tl-none px-4 py-3 max-w-xs">
                  <p class="text-slate-300 text-sm">Hola, ¿tienen la zapatilla en talle 42?</p>
                </div>
              </div>
              <div class="flex items-start gap-3 flex-row-reverse">
                <div class="w-8 h-8 rounded-full bg-violet-600/30 flex-shrink-0 flex items-center justify-center text-xs">🤖</div>
                <div class="bg-violet-600/15 border border-violet-600/20 rounded-2xl rounded-tr-none px-4 py-3 max-w-xs">
                  <p class="text-slate-200 text-sm">¡Claro! Tenemos stock en talle 42. También te cuento que hoy tiene 15% off. ¿Te lo reservo? 🎉</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex-shrink-0 flex items-center justify-center text-xs text-slate-300">👤</div>
                <div class="bg-[#1A1A28] rounded-2xl rounded-tl-none px-4 py-3 max-w-xs">
                  <p class="text-slate-300 text-sm">Sí, perfecto. ¿Cómo pago?</p>
                </div>
              </div>
              <div class="flex items-start gap-3 flex-row-reverse">
                <div class="w-8 h-8 rounded-full bg-violet-600/30 flex-shrink-0 flex items-center justify-center text-xs">🤖</div>
                <div class="bg-violet-600/15 border border-violet-600/20 rounded-2xl rounded-tr-none px-4 py-3 max-w-xs">
                  <p class="text-slate-200 text-sm">Te envío el link de pago ahora mismo 👇</p>
                </div>
              </div>
            </div>
            <!-- Badge IA activa -->
            <div class="absolute -bottom-5 -right-5 p-4 rounded-xl bg-[#1A1A28] border border-violet-600/20 flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-violet-400 animate-pulse"></span>
              <span class="text-slate-300 text-xs font-medium">IA activa 24/7</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 5. CASOS DE USO                              -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="Aplicaciones" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          Casos de Uso Especializados
        </h2>
        <p class="text-slate-400 text-lg max-w-xl mx-auto">
          Soluciones para los dos pilares críticos de cualquier tienda online exitosa.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Ventas -->
        <div
          data-aos="fade-right"
          class="group p-8 rounded-2xl bg-[#111118] border border-violet-600/20
                 hover:border-violet-600/40 transition-all duration-300"
        >
          <div class="w-14 h-14 bg-violet-600/10 rounded-xl flex items-center justify-center
                      text-2xl mb-6 group-hover:bg-violet-600/20 transition-colors duration-300">
            🛒
          </div>
          <h3 class="text-white font-bold text-2xl mb-4">Recuperación proactiva de ventas</h3>
          <p class="text-slate-400 leading-relaxed mb-6">
            Cuando un usuario abandona el checkout, el agente inicia una conversación personalizada
            ofreciendo ayuda, resolviendo dudas de envío o aplicando un cupón temporal.
          </p>
          <ul class="space-y-2.5">
            {['Reactivación vía WhatsApp', 'Cupones dinámicos', 'Manejo de objeciones de precio'].map((item) => (
              <li class="flex items-center gap-2.5 text-sm text-slate-300">
                <span class="w-1.5 h-1.5 rounded-full bg-violet-400 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Soporte -->
        <div
          data-aos="fade-left"
          data-aos-delay="100"
          class="group p-8 rounded-2xl bg-[#111118] border border-cyan-600/20
                 hover:border-cyan-600/40 transition-all duration-300"
        >
          <div class="w-14 h-14 bg-cyan-600/10 rounded-xl flex items-center justify-center
                      text-2xl mb-6 group-hover:bg-cyan-600/20 transition-colors duration-300">
            🎧
          </div>
          <h3 class="text-white font-bold text-2xl mb-4">Resolución Autónoma de Soporte</h3>
          <p class="text-slate-400 leading-relaxed mb-6">
            Centralizá todas las consultas de post-venta. El agente se conecta a tu ERP/Logística
            para dar estados reales de envío y gestionar cambios o devoluciones.
          </p>
          <ul class="space-y-2.5">
            {['Tracking de pedidos 24/7', 'FAQ dinámica contextual', 'Derivación humana inteligente'].map((item) => (
              <li class="flex items-center gap-2.5 text-sm text-slate-300">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 6. BENEFICIOS                                -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="Beneficios" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          Potenciá cada aspecto de tu operación
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {beneficios.map((b, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={String((i % 3) * 100)}
            class="rounded-2xl bg-[#111118] border border-white/[0.06]
                   hover:border-violet-600/20 transition-all duration-300 overflow-hidden"
          >
            <img
              src={b.image}
              alt={b.title}
              class="w-full h-28 object-cover object-center rounded-t-xl"
              loading="lazy"
            />
            <div class="p-6">
              <h4 class="text-white font-semibold mb-2">{b.title}</h4>
              <p class="text-slate-400 text-sm leading-relaxed">{b.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 7. PLANES                                    -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="Inversión" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          Planes diseñados para crecer
        </h2>
        <p class="text-slate-400 text-lg">Elegí el motor que impulsará tu tienda al siguiente nivel.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {planes.map((plan, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={String(i * 100)}
            class={`relative flex flex-col p-8 rounded-2xl transition-all duration-300
              ${plan.destacado
                ? 'bg-[#111118] border-2 border-violet-600 shadow-[0_0_40px_rgba(124,58,237,0.2)] scale-[1.03] z-10'
                : 'bg-[#111118] border border-white/[0.06] hover:border-violet-600/30'
              }`}
          >
            {plan.destacado && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2
                          bg-violet-600 text-white px-4 py-1 rounded-full
                          text-xs font-black uppercase tracking-widest">
                Más popular
              </div>
            )}

            <img
              src={plan.logo}
              alt={`Plan ${plan.nombre}`}
              class="h-28 w-auto object-contain mx-auto mb-6"
              loading="lazy"
            />

            <h3 class="text-white font-bold text-xl mb-6 text-center">{plan.nombre}</h3>

            <ul class="space-y-3 mb-10 flex-grow">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-slate-300">
                  <svg class="w-4 h-4 text-violet-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href="/contacto"
              class={`w-full py-3 rounded-xl font-bold text-center transition-all duration-300
                ${plan.destacado
                  ? 'bg-violet-600 hover:bg-violet-500 text-white shadow-[0_0_20px_rgba(124,58,237,0.3)]'
                  : 'border border-white/[0.12] text-white hover:bg-white/[0.04]'
                }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-slate-500 text-sm mt-10">
        Contratación mínima: 6 meses. Incluye onboarding, soporte, mantenimiento y mejoras continuas.
      </p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 8. CTA FINAL                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-4xl mx-auto relative" data-aos="fade-up">
      <div class="absolute -top-20 -left-20 w-64 h-64 rounded-full blur-[80px] pointer-events-none opacity-20"
           style="background: radial-gradient(circle, rgba(124,58,237,0.5), transparent);"></div>
      <div class="absolute -bottom-20 -right-20 w-64 h-64 rounded-full blur-[80px] pointer-events-none opacity-15"
           style="background: radial-gradient(circle, rgba(6,182,212,0.4), transparent);"></div>

      <div class="relative p-12 md:p-16 rounded-3xl text-center
                  bg-[#111118] border border-white/[0.06]">
        <SectionBadge text="¿Listo para escalar?" />
        <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-white mb-4">
          ¿Listo para transformar tus visitas en clientes leales?
        </h2>
