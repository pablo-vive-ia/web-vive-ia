---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBadge from '../components/SectionBadge.astro';
import MetricCounter from '../components/MetricCounter.astro';
import StepCard from '../components/StepCard.astro';
import HeroPhrase from '../components/HeroPhrase.astro';

const painPoints = [
  'Respondés las mismas preguntas una y otra vez',
  'Tus procesos dependen de personas clave que no pueden fallar',
  'Perdés leads por falta de seguimiento a tiempo',
  'Tu equipo gasta horas en tareas manuales y repetitivas',
  'No tenés visibilidad en tiempo real de lo que pasa en tu negocio',
  'El crecimiento genera más trabajo en vez de más libertad',
];

const steps = [
  {
    number: '01',
    title: 'Diagnóstico',
    description:
      'Analizamos tu negocio en profundidad: procesos actuales, herramientas, cuellos de botella y oportunidades reales de automatización.',
  },
  {
    number: '02',
    title: 'Orden',
    description:
      'Antes de automatizar, ordenamos. Documentamos tus flujos, eliminamos ineficiencias y establecemos las bases del sistema.',
  },
  {
    number: '03',
    title: 'Sistematización',
    description:
      'Convertimos tus procesos en sistemas replicables: procedimientos claros, herramientas conectadas y equipos alineados.',
  },
  {
    number: '04',
    title: 'Automatización con IA',
    description:
      'Incorporamos agentes de inteligencia artificial que ejecutan tareas, responden, siguen y escalan tu operación sin intervención manual.',
  },
];

const services = [
  {
    image: '/images/atencion-cliente.png',
    title: 'Agentes de Atención al Cliente',
    description:
      'Respondé consultas las 24 horas, 7 días a la semana. Tus clientes siempre atendidos, sin aumentar tu equipo.',
  },
  {
    image: '/images/ventas.png',
    title: 'Agentes de Ventas',
    description:
      'Calificá leads, hacé seguimiento automatizado y convertí más oportunidades sin intervención manual.',
  },
  {
    image: '/images/automatizacion.png',
    title: 'Automatización de Procesos',
    description:
      'Eliminá las tareas repetitivas de tu operación. Tus procesos internos funcionando solos, sin errores humanos.',
  },
  {
    image: '/images/integracion.png',
    title: 'Integración de Sistemas',
    description:
      'Conectamos tus herramientas existentes para que trabajen juntas: CRM, e-commerce, formularios, WhatsApp y más.',
  },
  {
    image: '/images/reportes.png',
    title: 'Reportes y Análisis Automáticos',
    description:
      'Generá reportes de tu negocio en forma automática. Datos actualizados en tiempo real para decidir más rápido.',
  },
  {
    image: '/images/e-commerce.png',
    title: 'Agentes para E-commerce',
    description:
      'Recuperá carritos abandonados, gestioná consultas de productos y mejorá la experiencia post-compra.',
    href: '/soluciones/ecommerce',
  },
  {
    image: '/images/mentores.png',
    title: 'Agentes para Mentores',
    description:
      'Escalá tu marca personal con IA. Automatizá la captación, el onboarding y el seguimiento de tus alumnos.',
    href: '/soluciones/mentores-marcas-personales',
  },
];

const benefits = [
  'Tu equipo se enfoca en lo estratégico, no en lo operativo',
  'Atención al cliente 24/7 sin aumentar costos',
  'Procesos consistentes, sin errores y escalables',
  'Seguimiento automático de leads y oportunidades',
  'Integración con las herramientas que ya usás',
  'Métricas y visibilidad en tiempo real',
];

const beforePoints = [
  'Equipo desbordado de tareas repetitivas',
  'Leads que se pierden por falta de seguimiento',
  'Procesos que dependen de personas específicas',
  'Atención al cliente limitada al horario laboral',
  'Crecimiento que genera más caos, no más orden',
];

const afterPoints = [
  'Equipo enfocado en lo que realmente genera valor',
  'Seguimiento automático y sin fisuras de cada lead',
  'Procesos documentados, automatizados y escalables',
  'Atención disponible las 24 horas, todos los días',
  'Crecimiento ordenado, predecible y sostenible',
];
---

<BaseLayout
  title="VIVE-IA — Automatizá tu negocio con Inteligencia Artificial"
  description="Ordenamos, estructuramos y automatizamos tus procesos para que tu empresa crezca sin caos. Agencia IA en Argentina."
>

  <!-- INTRO VIDEO — solo en Home -->
  <div id="intro-overlay" style="position:fixed;inset:0;z-index:9999;background:#0A0A0F;display:flex;align-items:center;justify-content:center;">
    <video
      id="intro-video"
      autoplay
      muted
      playsinline
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/video/logo-vive.mp4" type="video/mp4" />
    </video>
  </div>

  <script>
    const overlay = document.getElementById('intro-overlay');
    const video = document.getElementById('intro-video') as HTMLVideoElement;

    video.addEventListener('ended', () => {
      overlay!.style.transition = 'opacity 0.8s ease';
      overlay!.style.opacity = '0';
      setTimeout(() => overlay!.remove(), 800);
    });

    setTimeout(() => {
      if (overlay?.isConnected) {
        overlay.style.transition = 'opacity 0.8s ease';
        overlay.style.opacity = '0';
        setTimeout(() => overlay.remove(), 800);
      }
    }, 5000);
  </script>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 1. HERO                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">
    <!-- Video de fondo -->
    <div class="absolute inset-0 overflow-hidden z-0">
      <iframe
        src="https://www.youtube.com/embed/omr91fMMxk4?autoplay=1&mute=1&loop=1&playlist=omr91fMMxk4&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
        allow="autoplay; encrypted-media"
        allowfullscreen
        title="VIVE-IA video presentación"
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
               pointer-events-none border-none"
        style="width:100vw; height:56.25vw; min-height:100vh; min-width:177.77vh;"
      ></iframe>
    </div>

    <!-- Overlay oscuro degradado -->
    <div
      class="absolute inset-0 z-10"
      style="background: linear-gradient(135deg, rgba(10,10,15,0.88) 0%, rgba(10,10,15,0.72) 50%, rgba(10,10,15,0.88) 100%);"
    ></div>

    <!-- Partículas decorativas -->
    <div class="absolute top-20 right-20 w-72 h-72 rounded-full opacity-10 blur-3xl z-10"
         style="background: radial-gradient(circle, #7C3AED, transparent);"></div>
    <div class="absolute bottom-20 left-10 w-56 h-56 rounded-full opacity-8 blur-3xl z-10"
         style="background: radial-gradient(circle, #06B6D4, transparent);"></div>

    <!-- Contenido hero -->
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
      <div class="max-w-3xl">
        <div data-aos="fade-up">
          <SectionBadge text="Agencia de IA en Argentina 🇦🇷" />
        </div>

        <h1
          data-aos="fade-up"
          data-aos-delay="100"
          class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-[1.1] mb-6"
          style="background: linear-gradient(135deg, #F8FAFC 0%, #A855F7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        >
          Automatizá tu negocio con inteligencia artificial
        </h1>

        <div data-aos="fade-up" data-aos-delay="200" class="mb-10">
          <HeroPhrase />
        </div>

      </div>
    </div>

    <!-- Flecha scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- BANDA ESLÓGANES (ticker)                     -->
  <!-- ═══════════════════════════════════════════ -->
  <div
    class="py-5 overflow-hidden"
    style="background: linear-gradient(90deg, #0A0A0F 0%, #1A1A28 50%, #0A0A0F 100%); border-top:1px solid rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.06);"
  >
    <div class="flex items-center" style="width: max-content; animation: ticker 35s linear infinite;">
      <!-- Copia 1 -->
      <div class="flex items-center gap-8 text-xl font-medium italic pr-24">
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE la IA con propósito.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE la transformación de tu negocio.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE lo que tu empresa puede ser.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
      </div>
      <!-- Copia 2 (para loop sin corte) -->
      <div class="flex items-center gap-8 text-xl font-medium italic pr-24">
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE la IA con propósito.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE la transformación de tu negocio.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
        <span style="color:#A855F7;">✦</span>
        <span class="text-white">VIVE lo que tu empresa puede ser.</span>
        <span style="color:#A855F7;" class="text-2xl">·</span>
      </div>
    </div>
  </div>

  <style>
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
  </style>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 2. PROBLEMA                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-16" data-aos="fade-up">
        <SectionBadge text="¿Te suena familiar?" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          Si tu negocio crece…<br />
          <span class="text-slate-400">¿también crece el caos?</span>
        </h2>
        <p class="text-slate-400 text-lg">
          La mayoría de los negocios que escalan sin automatización terminan atrapados en su propio crecimiento.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {painPoints.map((point, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={String(i * 80)}
            class="flex items-start gap-4 p-5 rounded-xl bg-[#111118] border border-white/[0.06]
                   hover:border-red-500/20 transition-colors duration-300"
          >
            <span class="text-xl flex-shrink-0 mt-0.5">❌</span>
            <p class="text-slate-300 text-sm leading-relaxed">{point}</p>
          </div>
        ))}
      </div>

      <!-- Cierre -->
      <div class="text-center mt-16" data-aos="fade-up">
        <p class="text-white text-2xl font-bold">
          No te faltan clientes. Te falta estructura.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 3. PROCESO (4 pasos)                         -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Texto izquierda -->
        <div data-aos="fade-right">
          <SectionBadge text="Nuestro enfoque" />
          <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-6">
            Transformamos tu operación<br />
            <span style="background: linear-gradient(135deg, #A855F7 0%, #06B6D4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              en un sistema eficiente
            </span>
          </h2>
          <p class="text-slate-400 text-lg leading-relaxed mb-8">
            No tiramos tecnología al problema. Primero entendemos tu negocio, luego diseñamos la solución correcta y la implementamos sin interrumpir tu operación.
          </p>
        </div>

        <!-- Steps derecha -->
        <div data-aos="fade-left" data-aos-delay="100">
          {steps.map((step, i) => (
            <StepCard
              number={step.number}
              title={step.title}
              description={step.description}
              isLast={i === steps.length - 1}
            />
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 4. SERVICIOS (grid de cards)                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="Servicios" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          Soluciones inteligentes para<br />negocios que quieren crecer
        </h2>
        <p class="text-slate-400 text-lg max-w-xl mx-auto">
          Cada solución está adaptada a las necesidades reales de tu negocio, no a una plantilla genérica.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((service, i) => (
          service.href ? (
            <a
              href={service.href}
              data-aos="fade-up"
              data-aos-delay={String((i % 3) * 100)}
              class={`group rounded-2xl bg-[#111118] border border-violet-600/20
                     hover:border-violet-600/50 hover:-translate-y-1
                     transition-all duration-300 backdrop-blur-sm overflow-hidden
                     shadow-[0_0_20px_rgba(124,58,237,0.05)] hover:shadow-[0_0_30px_rgba(124,58,237,0.15)]`}
            >
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-24 object-cover rounded-t-xl"
                loading="lazy"
              />
              <div class="p-6">
                <h3 class="text-white font-semibold text-lg mb-3">
                  {service.title}
                </h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-4">{service.description}</p>
                <span class="inline-flex items-center gap-1 text-violet-400 text-xs font-medium group-hover:gap-2 transition-all duration-300">
                  Ver solución
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </a>
          ) : (
            <div
              data-aos="fade-up"
              data-aos-delay={String((i % 3) * 100)}
              class="group rounded-2xl bg-[#111118] border border-white/[0.06]
                     hover:border-violet-600/30 hover:-translate-y-1
                     transition-all duration-300 backdrop-blur-sm overflow-hidden"
            >
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-24 object-cover rounded-t-xl"
                loading="lazy"
              />
              <div class="p-6">
                <h3 class="text-white font-semibold text-lg mb-3">
                  {service.title}
                </h3>
                <p class="text-slate-400 text-sm leading-relaxed">{service.description}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 5. RESULTADOS + MÉTRICAS ANIMADAS            -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0D0D14]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Beneficios checklist -->
        <div data-aos="fade-right">
          <SectionBadge text="Resultados" />
          <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-10">
            Lo que cambia cuando automatizás bien
          </h2>
          <ul class="space-y-4">
            {benefits.map((benefit, i) => (
              <li
                data-aos="fade-right"
                data-aos-delay={String(i * 80)}
                class="flex items-start gap-3"
              >
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-violet-600/20 border border-violet-600/40
                             flex items-center justify-center mt-0.5">
                  <svg class="w-3.5 h-3.5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-slate-300 text-sm leading-relaxed">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Métricas animadas -->
        <div data-aos="fade-left" data-aos-delay="100">
          <div class="grid grid-cols-2 gap-6">
            <div class="p-6 rounded-2xl bg-[#111118] border border-white/[0.06] text-center
                        hover:border-violet-600/20 transition-colors duration-300">
              <MetricCounter value={1150} prefix="+" suffix="%" label="ROI E-commerce" />
            </div>
            <div class="p-6 rounded-2xl bg-[#111118] border border-white/[0.06] text-center
                        hover:border-violet-600/20 transition-colors duration-300">
              <MetricCounter value={400} prefix="+" suffix="%" label="ROI Mentores" />
            </div>
            <div class="p-6 rounded-2xl bg-[#111118] border border-white/[0.06] text-center
                        hover:border-violet-600/20 transition-colors duration-300">
              <MetricCounter value={24} suffix="/7" label="Disponibilidad" />
            </div>
            <div class="p-6 rounded-2xl bg-[#111118] border border-white/[0.06] text-center
                        hover:border-violet-600/20 transition-colors duration-300">
              <MetricCounter value={6} suffix="hrs" label="Liberadas por semana" />
            </div>
          </div>

          <!-- Aclaración -->
          <p class="text-slate-600 text-xs text-center mt-4">
            Resultados promedio observados en implementaciones con clientes.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- 6. DIFERENCIAL — Antes / Después             -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#0A0A0F] relative overflow-hidden">

    <!-- Canvas Three.js — fondo absoluto -->
    <canvas id="canvas-no-caos" class="absolute inset-0 w-full h-full" style="z-index:0;"></canvas>

    <!-- Overlay degradado para legibilidad -->
    <div class="absolute inset-0 pointer-events-none" style="z-index:1; background: linear-gradient(to bottom, rgba(10,10,15,0.2) 0%, rgba(10,10,15,0.05) 50%, rgba(10,10,15,0.2) 100%);"></div>

    <div class="max-w-7xl mx-auto relative" style="z-index:2;">
      <div class="text-center mb-16" data-aos="fade-up">
        <SectionBadge text="¿Por qué VIVE-IA?" />
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-semibold text-white mb-4">
          No automatizamos caos
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Antes de agregar tecnología, ordenamos tus procesos. Una automatización mal diseñada solo acelera el desorden.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">

        <!-- Antes -->
        <div data-aos="fade-right"
             class="p-8 rounded-2xl"
             style="border: 1px solid rgba(239,68,68,0.25); background: rgba(17,17,24,0.85); backdrop-filter: blur(12px);">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-8 h-8 rounded-full bg-red-900/30 flex items-center justify-center text-red-400 text-sm font-bold">✗</span>
            <h3 class="text-red-400 font-semibold text-lg">Sin VIVE-IA</h3>
          </div>
          <ul class="space-y-3">
            {beforePoints.map((point) => (
              <li class="flex items-start gap-3 text-sm text-slate-400">
                <span class="text-red-500/60 mt-1 flex-shrink-0">—</span>
                {point}
              </li>
            ))}
          </ul>
        </div>

        <!-- Después -->
        <div data-aos="fade-left" data-aos-delay="100"
             class="p-8 rounded-2xl shadow-[0_0_40px_rgba(124,58,237,0.08)]"
             style="border: 1px solid rgba(124,58,237,0.35); background: rgba(17,17,24,0.85); backdrop-filter: blur(12px);">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-8 h-8 rounded-full bg-violet-600/20 flex items-center justify-center text-violet-400 text-sm font-bold">✓</span>
            <h3 class="text-violet-400 font-semibold text-lg">Con VIVE-IA</h3>
          </div>
          <ul class="space-y-3">
            {afterPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <svg class="w-4 h-4 text-violet-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <script>
    import * as THREE from 'three';

    const canvasNoCaos = document.getElementById('canvas-no-caos') as HTMLCanvasElement;
    if (canvasNoCaos) {
      const rendererNC = new THREE.WebGLRenderer({ canvas: canvasNoCaos, antialias: true, alpha: true });
      rendererNC.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      rendererNC.setClearColor(0x000000, 0);

      const section = canvasNoCaos.parentElement!;
      rendererNC.setSize(section.offsetWidth, section.offsetHeight);

      const sceneNC = new THREE.Scene();
      const cameraNC = new THREE.PerspectiveCamera(60, section.offsetWidth / section.offsetHeight, 0.1, 100);
      cameraNC.position.z = 6;

      // — Nodos —
      const NODE_COUNT = 50;
      const positions: THREE.Vector3[] = [];
      const velocities: THREE.Vector3[] = [];
      // Fase aleatoria por nodo para el efecto destello
      const flashPhases = new Float32Array(NODE_COUNT);
      const flashSpeeds = new Float32Array(NODE_COUNT);
      for (let i = 0; i < NODE_COUNT; i++) {
        flashPhases[i] = Math.random() * Math.PI * 2;
        flashSpeeds[i] = 0.6 + Math.random() * 1.4; // velocidad de parpadeo variable por nodo
        positions.push(new THREE.Vector3(
          (Math.random() - 0.5) * 10,
          (Math.random() - 0.5) * 6,
          (Math.random() - 0.5) * 4,
        ));
        velocities.push(new THREE.Vector3(
          (Math.random() - 0.5) * 0.004,
          (Math.random() - 0.5) * 0.004,
          (Math.random() - 0.5) * 0.004,
        ));
      }

      // ShaderMaterial para destello por nodo
      const flashAttr = new THREE.BufferAttribute(new Float32Array(NODE_COUNT), 1);
      const pointsGeo = new THREE.BufferGeometry();
      const posArr = new Float32Array(NODE_COUNT * 3);
      positions.forEach((p, i) => { posArr[i * 3] = p.x; posArr[i * 3 + 1] = p.y; posArr[i * 3 + 2] = p.z; });
      pointsGeo.setAttribute('position', new THREE.BufferAttribute(posArr, 3));
      pointsGeo.setAttribute('flash', flashAttr);

      const pointsMat = new THREE.ShaderMaterial({
        transparent: true,
        uniforms: { pointSize: { value: 6.0 * window.devicePixelRatio } },
        vertexShader: `
          attribute float flash;
          varying float vFlash;
          uniform float pointSize;
          void main() {
            vFlash = flash;
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = pointSize * (1.0 + 0.6 * flash);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          varying float vFlash;
          void main() {
            float d = length(gl_PointCoord - vec2(0.5));
            if (d > 0.5) discard;
            float alpha = (0.55 + 0.4 * vFlash) * (1.0 - smoothstep(0.3, 0.5, d));
            gl_FragColor = vec4(0.486, 0.227, 0.929, alpha);
          }
        `,
      });
      const pointsMesh = new THREE.Points(pointsGeo, pointsMat);
      sceneNC.add(pointsMesh);

      // — Líneas —
      const linesMat = new THREE.LineBasicMaterial({ color: 0x7C3AED, transparent: true, opacity: 0.22 });
      const linesGeo = new THREE.BufferGeometry();
      const linesArr = new Float32Array(NODE_COUNT * NODE_COUNT * 6);
      linesGeo.setAttribute('position', new THREE.BufferAttribute(linesArr, 3));
      const linesMesh = new THREE.LineSegments(linesGeo, linesMat);
      sceneNC.add(linesMesh);

      const CONNECT_DIST = 2.0;

      function updateLinesNC() {
        const arr = linesGeo.attributes.position.array as Float32Array;
        let idx = 0;
        for (let i = 0; i < NODE_COUNT; i++) {
          for (let j = i + 1; j < NODE_COUNT; j++) {
            if (positions[i].distanceTo(positions[j]) < CONNECT_DIST) {
              arr[idx++] = positions[i].x; arr[idx++] = positions[i].y; arr[idx++] = positions[i].z;
              arr[idx++] = positions[j].x; arr[idx++] = positions[j].y; arr[idx++] = positions[j].z;
            }
          }
        }
        while (idx < arr.length) arr[idx++] = 0;
        linesGeo.attributes.position.needsUpdate = true;
        linesGeo.setDrawRange(0, idx / 3);
      }

      const clock = new THREE.Clock();

      function animateNC() {
        requestAnimationFrame(animateNC);
        const t = clock.getElapsedTime();

        // Actualizar destello por nodo (sin wave con fase y velocidad individual)
        const fArr = flashAttr.array as Float32Array;
        for (let i = 0; i < NODE_COUNT; i++) {
          fArr[i] = Math.max(0, Math.sin(t * flashSpeeds[i] + flashPhases[i]));
        }
        flashAttr.needsUpdate = true;

        // Mover nodos
        for (let i = 0; i < NODE_COUNT; i++) {
          positions[i].add(velocities[i]);
          if (Math.abs(positions[i].x) > 5) velocities[i].x *= -1;
          if (Math.abs(positions[i].y) > 3) velocities[i].y *= -1;
          if (Math.abs(positions[i].z) > 2) velocities[i].z *= -1;
        }

        // Actualizar posiciones
        const pArr = pointsGeo.attributes.position.array as Float32Array;
        positions.forEach((p, i) => { pArr[i * 3] = p.x; pArr[i * 3 + 1] = p.y; pArr[i * 3 + 2] = p.z; });
        pointsGeo.attributes.position.needsUpdate = true;

        updateLinesNC();

        // Rotación automática
        sceneNC.rotation.y += 0.002;

        rendererNC.render(sceneNC, cameraNC);
      }

      animateNC();

      // Resize
      window.addEventListener('resize', () => {
        const w = section.offsetWidth;
        const h = section.offsetHeight;
        rendererNC.setSize(w, h);
        cameraNC.aspect = w / h;
        cameraNC.updateProjectionMatrix();
      });
    }
  </script>


